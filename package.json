{
  "name": "webtoon-to-video-backend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "npm run start",
    "start": "node scripts/run-frontend.js",
    "frontend:dev": "npm run frontend",
    "backend": "node scripts/run-backend.js",
    "python": "npm run backend",
    "python:prod": "cd backend/python && cross-env NODE_ENV=production ..\\..\\.venv\\Scripts\\python.exe main.py",
    "frontend": "node scripts/run-frontend.js --only-frontend",
    "build:frontend": "vite build --config frontend/vite.config.ts",
    "build": "npm run build:frontend",
    "preview": "vite preview --config frontend/vite.config.ts",
    "typecheck": "tsc --noEmit",
    "test": "echo \"No tests specified\" && exit 0",
    "format": "prettier --write .",
    "start:prod": "npm run python:prod",
    "start:server": "npm run start:prod",
    "install:python": ".venv\\Scripts\\python.exe -m pip install -r requirements.txt",
    "clean": "rimraf dist",
    "docker:build": "docker build -t webtoon-to-video-backend .",
    "docker:run": "docker run -p 3000:3000 webtoon-to-video-backend",
    "lint": "tsc --noEmit --project frontend/tsconfig.json"
  },
  "dependencies": {
    "@google/genai": "^2.4.0",
    "@huggingface/inference": "^4.13.18",
    "@tailwindcss/vite": "^4.1.14",
    "@types/better-sqlite3": "^7.6.13",
    "@types/file-saver": "^2.0.7",
    "@vitejs/plugin-react": "^5.0.4",
    "better-sqlite3": "^12.10.0",
    "date-fns": "^4.4.0",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "file-saver": "^2.0.5",
    "image-size": "^2.0.2",
    "jszip": "^3.10.1",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "playwright": "^1.60.0",
    "react": "^19.0.1",
    "react-dom": "^19.0.1",
    "sharp": "^0.34.5",
    "uuid": "^14.0.0",
    "vite": "^6.2.3"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.19.20",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/uuid": "^10.0.0",
    "autoprefixer": "^10.4.21",
    "concurrently": "^10.0.3",
    "cross-env": "^10.1.0",
    "esbuild": "^0.25.0",
    "prettier": "^2.8.8",
    "rimraf": "^5.0.1",
    "tailwindcss": "4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.3"
  }
}
