# =============================================================================
# Webtoon-to-Video — Environment Variables
# =============================================================================
# Copy this file to .env and fill in your real values.
# NEVER commit .env to git — it is already in .gitignore
# =============================================================================

# ── AI / ML API Keys ──────────────────────────────────────────────────────────

# REQUIRED: Google Gemini API key — used for:
#   - AI panel detection (server.ts /api/ai-detect-panels)
#   - AI image analysis (server.ts /api/analyze-image)
#   - Speech bubble detection via Gemini vision (backend/services/cleaner.py)
# Get yours at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY="YOUR_GEMINI_API_KEY_HERE"

# OPTIONAL: HuggingFace API key — used for open-source model inference
#   - Enables Mistral 7B and Llama 3 model options in the UI
# Get yours at: https://huggingface.co/settings/tokens
HUGGINGFACE_API_KEY="YOUR_HUGGINGFACE_API_KEY_HERE"

# ── Server & App Configuration ────────────────────────────────────────────────

# The environment mode: "development" or "production"
# In development → Vite dev server runs separately on port 3000
# In production  → FastAPI serves static frontend files from /dist
NODE_ENV="development"

# Port the unified FastAPI backend runs on (default: 5173)
BACKEND_PORT=5173

# Port the React/Vite development server runs on (default: 3000)
FRONTEND_PORT=3000

# Public URL of the React/Vite development server (default: 3000)
# This is the URL you open in your browser to view the application.
APP_URL="http://localhost:3000"

# ── Database (Optional) ───────────────────────────────────────────────────────

# PostgreSQL connection string — for logging project history entries
# Leave empty if you are not using a database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/webtoon_db"

# ── Supabase (PostgreSQL Production Database) ──────────────────────────────────
# Connection string to your Supabase PostgreSQL instance
# Get from: https://app.supabase.com/project/<your-ref>/settings/database
# If this is set, the backend will automatically use PostgreSQL instead of local SQLite.
# Example: postgresql://postgres.xxxxxx:password@aws-0-us-west-1.pooler.supabase.com:6543/postgres
# DATABASE_URL="postgresql://user:pass@host:port/dbname"

# Supabase project URL — alternative to raw PostgreSQL
# Get from: https://app.supabase.com/project/<your-ref>/settings/api
SUPABASE_URL="https://your-project-ref.supabase.co"

# Supabase anon public key (safe to use client-side)
SUPABASE_KEY="your-supabase-anon-key-here"

# ── Vite Dev Server (Frontend) ────────────────────────────────────────────────

# Set to "true" to disable Vite Hot Module Replacement (HMR)
# Useful in cloud/container environments where WebSockets are blocked
DISABLE_HMR="false"

# =============================================================================
# QUICK SETUP GUIDE
# =============================================================================
# 1. Copy this file:       copy .env.example .env
# 2. Set GEMINI_API_KEY    (required for all AI features)
# 3. Set HUGGINGFACE_API_KEY (optional, for open-source models)
# 4. Run: npm run dev
# =============================================================================
